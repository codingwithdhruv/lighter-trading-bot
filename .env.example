# Lighter Trading Bot - Configuration Template
# Copy this file to .env and fill in your details.

# ==========================================
# 🛑 CORE SETTINGS (REQUIRED)
# ==========================================

# 1. LIGHTER API ENDPOINT
LIGHTER_API_URL=https://mainnet.zklighter.elliot.ai

# 2. YOUR ACCOUNT INDEX
# The unique ID for your account on Lighter (e.g. 21011).
# Connect to app.lighter.xyz and look at the "Account" section to find it.
LIGHTER_ACCOUNT_INDEX=0

# 3. YOUR API KEY INDEX
# The index of the API Key you generated. Usually 0 unless you have multiple keys.
LIGHTER_API_KEY_INDEX=0

# 4. YOUR API PRIVATE KEY
# 🛑 IMPORTANT: This is the PRIVATE KEY of your LIGHTER API KEY, NOT your wallet address.
# It should start with 0x...
LIGHTER_PRIVATE_KEY=your_lighter_api_private_key_here

# 5. TELEGRAM BOT TOKEN
# Obtain this from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 6. ALLOWED TELEGRAM USER IDS
# Security: Comma-separated list of IDs allowed to control the bot.
# Leave blank to allow everyone (NOT RECOMMENDED) or put your ID (e.g. 1060740758).
ALLOWED_TELEGRAM_USER_IDS=

# ==========================================
# ⚙️ OPERATIONAL SETTINGS
# ==========================================

# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# POLL_INTERVAL_SEC: Frequency to poll Lighter for order fills and UI positions (e.g., 10 or 15).
POLL_INTERVAL_SEC=15

# MAX_TRIGGER_SLIPPAGE: Max price difference allowed from trigger for a 'Closing' trade to execute.
MAX_TRIGGER_SLIPPAGE=150.0

# ==========================================
# 📡 COPY TRADING: DECIBEL.TRADE (OPTIONAL)
# ==========================================

# Decibel Wallet Private Key (Aptos)
DECIBEL_PRIVATE_KEY=

# Decibel API Key (from Geomi)
DECIBEL_API_KEY=

# Decibel RPC URL (Default is Aptos Mainnet)
DECIBEL_RPC_URL=https://fullnode.mainnet.aptoslabs.com

# Copy Configuration
DECIBEL_LEVERAGE=1
DECIBEL_ALLOCATION_USDC=100

# ==========================================
# 📡 COPY TRADING: COINDCX (OPTIONAL)
# ==========================================

# CoinDCX API Credentials
COINDCX_KEY=
COINDCX_SECRET=

# Copy Configuration
COINDCX_LEVERAGE=1
COINDCX_ALLOCATION_USDT=100
