# Lighter Bot Configuration Settings

# --- Lighter API Settings ---

# The API endpoint for Lighter.
LIGHTER_API_URL=https://mainnet.zklighter.elliot.ai

# 1. YOUR ACCOUNT INDEX
# This is the unique number for your account on Lighter (e.g., 21011).
# Connect to app.lighter.xyz to see it or run 'python find_account_index.py'
LIGHTER_ACCOUNT_INDEX=0

# 2. YOUR API KEY INDEX
# The index of the API key within your account. Default is 0.
LIGHTER_API_KEY_INDEX=0

# 3. YOUR API PRIVATE KEY
# 🛑 IMPORTANT: This is the PRIVATE KEY of your LIGHTER API KEY, NOT your MetaMask Wallet!
# You generate this in the Lighter UI under Settings -> API Keys.
# It should start with 0x...
LIGHTER_PRIVATE_KEY=your_lighter_api_private_key_here

# --- Telegram Bot Settings ---

# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Security: Comma-separated list of allowed Telegram user IDs (e.g. 1060740758)
ALLOWED_TELEGRAM_USER_IDS=
